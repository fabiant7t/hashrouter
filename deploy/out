apiVersion: v1
kind: ServiceAccount
metadata:
  name: hashrouter
  namespace: hashrouter
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: hashrouter-service-registry
rules:
- apiGroups:
  - ""
  resources:
  - services
  verbs:
  - get
  - list
  - watch
- apiGroups:
  - discovery.k8s.io
  resources:
  - endpointslices
  verbs:
  - get
  - list
  - watch
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: hashrouter-service-registry
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: hashrouter-service-registry
subjects:
- kind: ServiceAccount
  name: hashrouter
  namespace: hashrouter
---
apiVersion: v1
kind: Service
metadata:
  labels:
    app.kubernetes.io/name: hashrouter
  name: hashrouter
  namespace: hashrouter
spec:
  ports:
  - name: http
    port: 80
    protocol: TCP
    targetPort: http
  selector:
    app.kubernetes.io/name: hashrouter
  type: ClusterIP
---
apiVersion: apps/v1
kind: Deployment
metadata:
  labels:
    app.kubernetes.io/name: hashrouter
  name: hashrouter
  namespace: hashrouter
spec:
  replicas: 5
  selector:
    matchLabels:
      app.kubernetes.io/name: hashrouter
  template:
    metadata:
      labels:
        app.kubernetes.io/name: hashrouter
    spec:
      affinity:
        podAntiAffinity:
          preferredDuringSchedulingIgnoredDuringExecution:
          - podAffinityTerm:
              labelSelector:
                matchLabels:
                  app.kubernetes.io/name: hashrouter
              topologyKey: kubernetes.io/hostname
            weight: 100
      containers:
      - image: docker.io/fabiant7t/hashrouter:v0.0.3
        imagePullPolicy: IfNotPresent
        livenessProbe:
          httpGet:
            path: /healthz
            port: http
          initialDelaySeconds: 5
          periodSeconds: 10
        name: hashrouter
        ports:
        - containerPort: 8080
          name: http
        readinessProbe:
          httpGet:
            path: /healthz
            port: http
          initialDelaySeconds: 2
          periodSeconds: 5
        resources:
          limits:
            cpu: 500m
            memory: 256Mi
          requests:
            cpu: 100m
            memory: 64Mi
      serviceAccountName: hashrouter
      topologySpreadConstraints:
      - labelSelector:
          matchLabels:
            app.kubernetes.io/name: hashrouter
        maxSkew: 1
        topologyKey: kubernetes.io/hostname
        whenUnsatisfiable: ScheduleAnyway
